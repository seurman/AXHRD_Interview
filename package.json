{
  "name": "hr-in-solution",
  "private": true,
  "description": "HR_IN Solution monorepo root — D:\\HR_IN_Solution",
  "scripts": {
    "setup": "powershell -ExecutionPolicy Bypass -File ./scripts/setup.ps1",
    "dev": "powershell -ExecutionPolicy Bypass -File ./scripts/dev.ps1",
    "infra": "powershell -ExecutionPolicy Bypass -File ./scripts/infra.ps1",
    "verify": "node scripts/verify.mjs",
    "verify:start": "node scripts/verify.mjs --start --fix",
    "start": "node scripts/verify.mjs --start --fix && npm run dev --prefix web",
    "web:dev": "npm run dev --prefix web",
    "web:build": "npm run build --prefix web",
    "web:seed": "npm run db:seed --prefix web",
    "db:seed": "npm run db:seed --prefix web",
    "db:seed:real": "npm run db:seed:real --prefix web",
    "db:migrate": "npm run db:migrate --prefix web"
  }
}
