# HR_IN Solution — D:\HR_IN_Solution
# Next.js는 web/.env 를 읽습니다. 루트 .env 와 동일하게 유지하세요.
DATABASE_URL="postgresql://hrin:hrin@localhost:5432/hr_in_solution?schema=public"
DIRECT_URL="postgresql://hrin:hrin@localhost:5432/hr_in_solution?schema=public"

# ── IRT Engine ──
IRT_ENGINE_URL="http://localhost:8000"

# ── Gemini (저비용: TTS + 실시간 채점 + 질문 개인화, 비중국 벤더) ──
# aistudio.google.com/apikey 에서 무료 발급
GEMINI_API_KEY=""
GEMINI_TEXT_MODEL="gemini-2.5-flash-lite"
GEMINI_TTS_MODEL="gemini-2.5-flash-preview-tts"
GEMINI_TTS_VOICE="Kore"

# ── DeepSeek (세션 리포트 + 역량 피드백 생성, 가성비) ──
DEEPSEEK_API_KEY=""
DEEPSEEK_REPORT_MODEL="deepseek-chat"

# ── Neo4j (온톨로지 그래프 DB — AWS 이전 시 AuraDB 등으로 교체) ──
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="hrin_graph_2026"
NEO4J_ENABLED="true"

# ── App ──
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ── 소셜 로그인 (카카오/네이버) ──
# 카카오: developers.kakao.com > 내 애플리케이션 > 앱 키(REST API 키)
#   카카오 로그인 활성화 + Redirect URI 등록: {NEXT_PUBLIC_APP_URL}/api/auth/oauth/kakao/callback
#   동의항목에서 "카카오계정(이메일)"을 필수/선택 동의로 설정
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""

# 네이버: developers.naver.com > Application 등록
#   서비스 URL / Callback URL 등록: {NEXT_PUBLIC_APP_URL}/api/auth/oauth/naver/callback
#   제공 정보에서 이메일, 이름 항목 체크
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

# ── DART (상장사 정보, 선택) ──
DART_API_KEY=""
