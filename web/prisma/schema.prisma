generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Supabase 커넥션 풀러(6543, pgbouncer)는 prepared statement를 지원하지
  // 않아 prisma migrate가 실패한다. 마이그레이션 전용으로 direct 연결(5432)을
  // 별도로 지정한다 — 평소 앱 쿼리는 DATABASE_URL(풀링)을 그대로 사용.
  directUrl = env("DIRECT_URL")
}

// ── Enums ──

enum CompanySize {
  LARGE       // 대기업
  MID         // 중견
  SMALL       // 중소
  STARTUP     // 스타트업
  PUBLIC      // 공기업/공사
}

enum SessionStatus {
  SETUP
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum PlanStatus {
  IN_PROGRESS
  COMPLETED
  PAUSED
}

enum CompetencyProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum SessionMode {
  COMPETENCY
  FULL
}

enum ChipType {
  PASS
  ATTEMPT
  DOWNGRADE
}

enum JobRole {
  MARKETING
  DEVELOPMENT
  BUSINESS_SUPPORT
  SALES
  DESIGN
  HR
  FINANCE
  OTHER
}

/** 특정 기업명 대신 선택하는 산업군 — 회사명 추측(휴리스틱)보다 신뢰도 높은
 *  질문 톤/실제 기출 질문 매칭의 기준이 된다. 소규모로 시작, 추후 마이그레이션으로 확장 가능. */
enum Industry {
  IT_SW
  FINANCE
  MANUFACTURING
  PUBLIC
  OTHER
}

enum OAuthProvider {
  KAKAO
  NAVER
}

// ── Organization (대학 취업센터 등 B2B2C 코호트) ──

enum OrgRole {
  STUDENT // 소속 학생/구직자 — 본인 결과만 조회
  STAFF   // 취업센터 담당자 — 소속 기관 코호트 집계 조회
  ADMIN   // 기관 생성자 — STAFF 권한 + 가입 코드 재발급 등 관리
}

/** 기관 생성 승인 절차. 아무나 로그인해서 기관을 만들고 ADMIN이 되는 것을
 *  막기 위해, 신규 생성 기관은 PENDING 상태로 시작해 슈퍼어드민 승인 전까지
 *  가입 코드로 학생을 받을 수 없고 대시보드도 열리지 않는다. */
enum OrgStatus {
  PENDING
  APPROVED
  REJECTED
}

/** 플랫폼(콘텐츠·운영) 권한 — OrgRole(기관 소속)과 별개.
 *  SUPERADMIN_EMAILS 환경변수도 슈퍼어드민으로 인정(부트스트랩용). */
enum PlatformRole {
  NONE
  CONTENT_ADMIN
  SUPERADMIN
}

model Organization {
  id         String    @id @default(cuid())
  name       String
  /** 학생/직원이 소속을 연결할 때 입력하는 코드. 재발급 가능하도록 unique만 보장 */
  joinCode   String    @unique
  status     OrgStatus @default(PENDING)
  approvedAt DateTime?
  rejectedAt DateTime?
  createdAt  DateTime  @default(now())

  members User[]
}

// ── User ──

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String
  phone           String?
  passwordHash    String?
  /** 역량 인증서 공개 공유 링크용 토큰 (/c/[slug]). 요청 시 생성되는 opaque 토큰 */
  certificateSlug String?  @unique
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id])
  orgRole         OrgRole  @default(STUDENT)
  /** 문항·역량·루브릭 CMS 및 플랫폼 권한 관리 */
  platformRole    PlatformRole @default(NONE)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  profile         UserProfile?
  targetCompanies TargetCompany[]
  resumes         Resume[]
  sessions        InterviewSession[]
  competencyLogs  CompetencySnapshot[]
  interviewPlans  InterviewPlan[]
  competencyProgress CompetencyProgress[]
  oauthAccounts   OAuthAccount[]
  swipeActions    SwipeAction[]

  @@index([organizationId])
}

// ── Social login (카카오/네이버) ──
// 이메일/비밀번호 없이도 가입 가능하도록 User.passwordHash는 nullable 유지.
// 향후 다른 provider 추가 시 enum만 확장하면 됨.
model OAuthAccount {
  id                String        @id @default(cuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          OAuthProvider
  providerAccountId String
  providerEmail     String?
  createdAt         DateTime      @default(now())

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model UserProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  careerYears     Int       @default(0)
  education       String?
  desiredJobRole  JobRole   @default(OTHER)
  /** 질문 카드(스와이프)에서 보여줄 기본 산업군 — 사용자가 명시적으로 고른 값.
   *  null이면 아직 한 번도 고르지 않은 상태(랜덤 대신 선택을 요구한다) */
  desiredIndustry Industry?
  bio             String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ── Company context ──

model TargetCompany {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  industry     String?
  /** 사용자가 직접 선택한 산업군 — industry(문자열 라벨)는 이 값을 기반으로 채워짐 */
  industryCode Industry?
  size         CompanySize @default(LARGE)
  interviewStyle Json?     // { tone, rounds, focus[] }
  /** 산업군+직무를 합쳐 결정한 지원자 페르소나 { id, name, description, toneHint, focusCompetencies }
   *  — 채점에는 영향 없음, 화면 뱃지·리포트 코칭 문구 전용 (lib/interview/persona-archetype.ts) */
  persona      Json?
  enrichedAt   DateTime?
  createdAt    DateTime    @default(now())

  sessions InterviewSession[]
  plans    InterviewPlan[]

  @@index([userId])
}

// ── Resume ──

model Resume {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName    String
  fileUrl     String?
  rawText     String   @db.Text
  parsedTags  Json?    // { skills[], experiences[], keywords[] }
  createdAt   DateTime @default(now())

  sessions InterviewSession[]
  plans    InterviewPlan[]

  @@index([userId])
}

// ── Interview plan (역량별 진행 트랙) ──

model InterviewPlan {
  id              String     @id @default(cuid())
  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetCompanyId String?
  targetCompany   TargetCompany? @relation(fields: [targetCompanyId], references: [id])
  resumeId        String?
  resume          Resume?    @relation(fields: [resumeId], references: [id])
  jobRole         JobRole    @default(OTHER)
  status          PlanStatus @default(IN_PROGRESS)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  competencyProgress CompetencyProgress[]
  sessions           InterviewSession[]

  @@index([userId, status])
}

model CompetencyProgress {
  id            String                   @id @default(cuid())
  planId        String
  plan          InterviewPlan            @relation(fields: [planId], references: [id], onDelete: Cascade)
  userId        String
  user          User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  competency    String
  status        CompetencyProgressStatus @default(NOT_STARTED)
  latestTheta   Float?
  levelEst      Int?
  percentile    Float?
  lastSessionId String?
  completedAt   DateTime?
  updatedAt     DateTime                 @updatedAt

  feedback CompetencyFeedback?

  @@unique([planId, competency])
  @@index([userId, competency])
}

model CompetencyFeedback {
  id           String             @id @default(cuid())
  progressId   String             @unique
  progress     CompetencyProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)
  sessionId    String
  summary      String             @db.Text
  strengths    Json
  improvements Json
  dimensions     Json?
  suggestions    Json
  highlights     Json?
  rewriteExample String?  @db.Text
  /** "이 페르소나답게 답변했는가" 1문장 코칭 — TargetCompany.persona가 있을 때만 채워짐 */
  personaAlignmentNote String? @db.Text
  generatedAt    DateTime @default(now())
}

// ── Question bank ──

model Competency {
  id          String   @id @default(cuid())
  code        String   @unique
  nameKo      String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  questions   Question[]
}

model Question {
  id             String     @id @default(cuid())
  externalId     String     @unique
  competencyId   String
  competency     Competency @relation(fields: [competencyId], references: [id])
  level          Int        // 1-5 UX level
  difficulty     Float      // IRT b parameter
  discrimination Float      @default(1.0)
  template       String     @db.Text
  followUpHints  Json?
  /** 관리자가 미리 정의한 채점 루브릭(문자열 배열). 없으면 세션 시 일반/LLM 루브릭 사용 */
  rubricCriteria Json?
  sortOrder      Int        @default(0)
  isActive       Boolean    @default(true)

  responses ResponseRecord[]

  @@index([competencyId, level])
}

// ── Interview session ──

model InterviewSession {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId          String?
  plan            InterviewPlan? @relation(fields: [planId], references: [id])
  targetCompanyId String?
  targetCompany   TargetCompany? @relation(fields: [targetCompanyId], references: [id])
  resumeId        String?
  resume          Resume?       @relation(fields: [resumeId], references: [id])
  jobRole         JobRole       @default(OTHER)
  focusCompetency String?
  mode            SessionMode   @default(COMPETENCY)
  status          SessionStatus @default(SETUP)
  sessionNumber   Int
  startedAt       DateTime?
  completedAt     DateTime?
  overallTheta    Float?
  irtState        Json?
  createdAt       DateTime      @default(now())

  responses ResponseRecord[]
  chipEvents ChipEvent[]
  report    SessionReport?

  @@index([userId, sessionNumber])
  @@index([planId])
  @@index([status])
}

model ResponseRecord {
  id          String           @id @default(cuid())
  sessionId   String
  session     InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionId  String
  question    Question         @relation(fields: [questionId], references: [id])
  competency  String
  level       Int
  transcript  String           @db.Text
  correctedTranscript String?  @db.Text
  audioUrl    String?
  rubricScore Float            // 0.0 - 1.0 (꼬리질문이 있었다면 최종 결합 평가 점수)
  durationSec Int?
  createdAt   DateTime         @default(now())

  // ── AI 꼬리질문(follow-up) — 답변이 추상적/모호할 때 같은 문항 안에서 한 번 더 파고든 기록 ──
  /** 꼬리질문이 없었다면 null. 있었다면 rubricScore는 원 답변+꼬리질문 답변을 함께 본 최종 점수 */
  initialRubricScore   Float?
  followUpQuestion     String? @db.Text
  followUpTranscript   String? @db.Text
  followUpCorrectedTranscript String? @db.Text

  @@index([sessionId])
}

model ChipEvent {
  id            String           @id @default(cuid())
  sessionId     String
  session       InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  competency    String
  level         Int
  chipType      ChipType
  rubricScore   Float
  briefFeedback String?
  /** 이 문항에 꼬리질문이 있었는지 — 리포트/투명성 표시용 */
  hadFollowUp   Boolean          @default(false)
  sequence      Int
  createdAt     DateTime         @default(now())

  @@index([sessionId])
}

// ── Longitudinal tracking ──

model CompetencySnapshot {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId   String
  competency  String
  theta       Float
  se          Float
  levelEst    Int
  percentile  Float
  recordedAt  DateTime @default(now())

  @@index([userId, competency])
  @@index([userId, recordedAt])
}

// ── Report (Claude-generated) ──

model SessionReport {
  id          String           @id @default(cuid())
  sessionId   String           @unique
  session     InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  summaryHtml String           @db.Text
  summaryJson Json             // structured sections for charts
  generatedAt DateTime         @default(now())
}

// ── 실제 기출 질문 참고 (IRT 채점 문항 뱅크와는 별개 — 난이도/판별력 파라미터 없음) ──
// 공개 검색으로 수집한 실제 인터뷰 후기·커뮤니티 글에서 정리한 질문 + 근거가 부족한
// 산업군/직무 조합은 isAiExample=true로 표시해 AI가 만든 예시임을 투명하게 구분한다.
model RealInterviewQuestion {
  id           String   @id @default(cuid())
  industry     Industry
  jobRole      JobRole
  /** 역량 코드(느슨한 태그, COMPETENCY_CODES와 매칭 시도 — 필수 아님) */
  competency   String?
  questionText String   @db.Text
  /** 실제 출처 사이트명(예: "링커리어 커뮤니티"). AI 생성 예시면 null */
  sourceName   String?
  sourceUrl    String?
  isAiExample  Boolean  @default(false)
  createdAt    DateTime @default(now())

  swipeActions SwipeAction[]

  @@index([industry, jobRole])
}

// ── 질문 카드 스와이프(모바일 습관형성 루프) ──
// 사용자가 명시적으로 고른 산업군·직무에 맞는 실제 기출 질문 카드를 넘기며
// Pass/Save 한다. 채점과 무관한 순수 열람·북마크 기록.
enum SwipeActionType {
  PASS
  SAVE
}

model SwipeAction {
  id         String                @id @default(cuid())
  userId     String
  user       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId String
  question   RealInterviewQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  action     SwipeActionType
  /** Save한 질문에 실제로 음성 답변을 녹음해본 기록(자체 STT 텍스트만, 채점 없음).
   *  "저장"이 단순 북마크로 끝나지 않고 그 자리에서 답변 연습까지 이어지도록 함 */
  answerTranscript String?  @db.Text
  answeredAt       DateTime?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  @@unique([userId, questionId])
  @@index([userId, action])
}
