# ── Database (Supabase 등 프로덕션 Postgres 연결 문자열) ──
# DATABASE_URL: 앱 런타임 쿼리용 — Supabase "Transaction pooler" 연결 (포트 6543)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/DBNAME?pgbouncer=true"
# DIRECT_URL: prisma migrate 전용 — Supabase "Direct connection" (포트 5432)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME"

# ── IRT Engine (Render에 배포한 FastAPI 서비스 URL) ──
IRT_ENGINE_URL="https://axhrd-irt-engine.onrender.com"

# ── Gemini (TTS + 실시간 채점 + 질문 개인화) ──
GEMINI_API_KEY=""
GEMINI_TEXT_MODEL="gemini-2.5-flash-lite"
# 자소서 첨삭 전용 (문장 품질). 미설정 시 gemini-2.5-pro
GEMINI_RESUME_REVIEW_MODEL="gemini-2.5-pro"
GEMINI_RESUME_REVIEW_FALLBACK_MODEL="gemini-2.5-flash"
GEMINI_TTS_MODEL="gemini-2.5-flash-preview-tts"
GEMINI_TTS_VOICE="Kore"

# ── DeepSeek (세션 리포트 + 역량 피드백 생성, 선택) ──
DEEPSEEK_API_KEY=""
DEEPSEEK_REPORT_MODEL="deepseek-chat"

# ── Neo4j (온톨로지 그래프, 선택 — 미사용 시 NEO4J_ENABLED=false) ──
NEO4J_URI=""
NEO4J_USER=""
NEO4J_PASSWORD=""
NEO4J_ENABLED="false"

# ── App (프로덕션 도메인) ──
NEXT_PUBLIC_APP_URL="https://app.axhrd.com"
NEXTAUTH_SECRET=""
NEXTAUTH_URL="https://app.axhrd.com"

# ── 소셜 로그인 (카카오/네이버) — 각 콘솔에서 redirect URI를
#    https://app.axhrd.com/api/auth/oauth/kakao/callback 형식으로 등록 필요 ──
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

# ── DART (상장사 정보, 선택) ──
DART_API_KEY=""

# ── 플랫폼 슈퍼어드민 (기관 승인·문항 CMS 등 /admin 접근, 콤마로 구분) ──
# Vercel Production에도 반드시 설정 후 재배포. 로그인 이메일과 일치해야 함.
# 카카오 로그인은 kakao_...@oauth.hr-in.local 형태일 수 있음 — 프로필에서 확인.
SUPERADMIN_EMAILS="seurman@gmail.com"

# ── 토스페이먼츠 정기결제(빌링) — 개발자센터 테스트 키로 로컬 연동 ──
# https://docs.tosspayments.com/guides/v2/billing
NEXT_PUBLIC_TOSS_CLIENT_KEY=""
TOSS_SECRET_KEY=""
# Vercel Cron 인증 (vercel.json → /api/billing/cron). `openssl rand -hex 32` 등으로 생성
CRON_SECRET=""
