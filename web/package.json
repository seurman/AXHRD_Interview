    "db:seed:rubrics": "tsx prisma/seed-rubrics.ts",
    "db:seed:global": "tsx prisma/seed-global-competencies.ts",
    "db:seed:meaning": "tsx prisma/seed-meaning-layer.ts",
    "db:seed:demo-arc": "tsx prisma/seed/demo-arc-index.ts",
